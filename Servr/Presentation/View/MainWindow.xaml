<Window x:Class="Servr.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModel="clr-namespace:Servr.Presentation.ViewModel"
        xmlns:model="clr-namespace:Servr.Domain.Model"
        xmlns:local="clr-namespace:Servr"
        mc:Ignorable="d"
        Title="Servr" Height="768" Width="1024">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="450"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left column -->
        <Grid Grid.Column="0" Background="#F5F5F5">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <!-- Order View -->
            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="{Binding TableNumber, StringFormat='Table {0}', FallbackValue='No table set'}"
           FontSize="18" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20"/>
                    <ScrollViewer MaxHeight="500" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding OrderView}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="WhiteSmoke" Padding="15" Margin="0,0,5,5">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding Description}" FontSize="12" Foreground="#2C3E50" Margin="0,4,0,0"/>
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding Price}" FontSize="16" FontWeight="Bold" Foreground="#2C3E50" Margin="0,6,0,0"/>
                                            <Button Grid.Row="0" Grid.RowSpan="3" Grid.Column="1"
                                                    Content="Extras" VerticalAlignment="Center" Padding="8,4"
                                                    Command="{Binding DataContext.AddExtraCommand,
                                                        RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>

<!-- Order actions -->
<Border Grid.Row="1" Background="LightGray" Padding="15">
    <StackPanel>
            <!-- Top Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Cancel Order" Command="{Binding CancelOrderCommand}" Background="Gray"/>
            <Button Content="Send Order" Command="{Binding SendOrderCommand}" Background="LightBlue" Margin="8,0,0,0"/>
        </StackPanel>
                <!-- Summary -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding CurrentTableBill.Subtotal, StringFormat='Subtotal: {0} kr.', TargetNullValue='Subtotal: 0', FallbackValue='Subtotal: 0'}"/>
            <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding CurrentTableBill.DiscountAmount, StringFormat='Discount: {0} kr.', TargetNullValue='Discount: 0', FallbackValue='Discount: 0'}"/>
            <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding CurrentTableBill.BillTotal, StringFormat='Total: {0} kr.', TargetNullValue='Total: 0', FallbackValue='Total: 0'}"/>
        </Grid>
                    <!-- Bottom Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Command="{Binding SetTableCommand}" Background="Gray" Margin="8,0,0,0">
                <TextBlock Text="{Binding TableNumber, StringFormat='Table ({0})'}"/>
            </Button>
            <Button Command="{Binding DiscountCommand}" Background="Gray" Margin="8,0,0,0"
                    Content="{Binding DiscountType, StringFormat='Discount: {0}'}"/>
            <Button Command="{Binding PayCommand}" Content="Pay" Background="LightBlue" Margin="8,0,0,0"/>
        </StackPanel>
    </StackPanel>
</Border>
        </Grid>

<!-- Right column -->
<Grid Grid.Column="1">
    <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- Category buttons -->
    <ItemsControl Grid.Row="0" ItemsSource="{Binding CategoryOptions}" Margin="8,8,8,4">
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <UniformGrid Rows="1"/>
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <Button Margin="3" Height="52"
                        Content="{Binding}"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Command="{Binding DataContext.SelectCategoryCommand,
                            RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="{Binding}"/>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>

    <!-- Item buttons -->
    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
    <ItemsControl ItemsSource="{Binding CurrentItems}">
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <WrapPanel Orientation="Horizontal" Margin="8"/>
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <Button Width="120" Height="120" Margin="4"
                        Command="{Binding DataContext.AddItemCommand,
                            RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="{Binding}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}"
                                   FontSize="13" FontWeight="SemiBold"
                                   TextWrapping="Wrap" TextAlignment="Center"
                                   MaxWidth="100"/>
                        <TextBlock Text="{Binding Price, StringFormat={}{0:N0} kr}"
                                   FontSize="12" TextAlignment="Center"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </Button>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
</ScrollViewer>
</Grid>

        <!-- Toast Notification -->
        <Border x:Name="ToastNotification"
                Grid.ColumnSpan="2"
                Background="#2C3E50" CornerRadius="6"
                Padding="16,10" Margin="0,12,12,0"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Panel.ZIndex="100"
                Visibility="Collapsed"
                Opacity="0.95"
                MouseLeftButtonDown="ToastNotification_MouseLeftButtonDown"
                Cursor="Hand">
            <TextBlock x:Name="ToastText" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Window>
