<Window x:Class="Servr.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModel="clr-namespace:Servr.Presentation.ViewModel"
        xmlns:model="clr-namespace:Servr.Domain.Model"
        xmlns:local="clr-namespace:Servr"
        mc:Ignorable="d"
        Title="Servr" Height="768" Width="1024">
    <Window.DataContext>
        <viewModel:MainViewModel/>
    </Window.DataContext>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="450"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left column -->
        <Grid Grid.Column="0" Background="#F5F5F5">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <!-- Order View -->
            <Border Background="White" BorderBrush="#E0E0E0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Order" FontSize="18" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20"/>
                    <ScrollViewer MaxHeight="500" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding OrderView}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="WhiteSmoke" Padding="15" Margin="0,0,5,5">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                            <TextBlock Grid.Row="1" Text="{Binding Description}" FontSize="12" Foreground="#2C3E50" Margin="0,4,0,0"/>
                                            <TextBlock Grid.Row="2" Text="{Binding Price}" FontSize="16" FontWeight="Bold" Foreground="#2C3E50" Margin="0,6,0,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>

<!-- Order actions -->
<Border Grid.Row="1" Background="LightGray" Padding="15">
    <StackPanel>
            <!-- Top Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Cancel Order" Command="{Binding CancelOrderCommand}" Background="Gray"/>
            <Button Content="Send Order" Command="{Binding SendOrderCommand}" Background="LightBlue" Margin="8,0,0,0"/>
        </StackPanel>
                <!-- Summary -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding CurrentTableBill.Subtotal}"/>
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Discount: "/>
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Tax: "/>
            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CurrentTableBill.BillTotal}"/>
            <TextBlock Grid.Row="1" Grid.Column="1" Text="Balance Due: "/>
            <TextBlock Grid.Row="2" Grid.Column="1" Text="Tips: "/>
        </Grid>
                    <!-- Bottom Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Command="{Binding SetTableCommand}" Background="Gray" Margin="8,0,0,0"
                    Content="{Binding TableNumber, StringFormat='Table: {0}'}"/>
            <Button Command="{Binding DiscountCommand}" Background="Gray" Margin="8,0,0,0"
                    Content="{Binding DiscountType, StringFormat='Discount: {0}'}"/>
            <Button Content="Pay" Background="LightBlue" Margin="8,0,0,0"/>
        </StackPanel>
    </StackPanel>
</Border>
        </Grid>

        <!-- Right column -->
        <StackPanel Grid.Column="1" Background="#FFFFFF">
            <!-- Category buttons -->
            <ItemsControl ItemsSource="{Binding CategoryOptions}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="4">
                            <Button Content="{Binding}"
                                    Command="{Binding DataContext.SelectCategoryCommand,
                                        RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Items list -->
            <ListView ItemsSource="{Binding CurrentItems}" SelectedItem="{Binding SelectedItem}">
                <ListView.Resources>
                    <DataTemplate DataType="{x:Type model:MenuItem}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Name}" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding Price, StringFormat={}{0:N2} kr}"/>
                        </StackPanel>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type model:Drink}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Name}" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding Price, StringFormat={}{0:N2} kr}" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding Volume, StringFormat={}{0} cl}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListView.Resources>
            </ListView>
        </StackPanel>
    </Grid>
</Window>
