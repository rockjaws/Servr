<Window x:Class="Servr.Presentation.View.ExtrasDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Extras" Height="300" Width="280"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <StackPanel Margin="16">
        <TextBlock Text="{Binding ItemHeader}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
        <ItemsControl ItemsSource="{Binding Extras}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,4" Padding="6" Background="WhiteSmoke">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Price, StringFormat='{}{0:N2} kr'}" FontSize="11" Foreground="Gray"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="+" Width="30" Height="30" Margin="4,0"
                                    Click="OnAdd" Tag="{Binding}" FontWeight="Bold" Background="LightGreen"/>
                            <Button Grid.Column="2" Content="-" Width="30" Height="30"
                                    Click="OnRemove" Tag="{Binding}" FontWeight="Bold" Background="LightCoral"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <Button Content="Close" HorizontalAlignment="Right" Width="70" Margin="0,12,0,0" Click="OnClose"/>
    </StackPanel>
</Window>
