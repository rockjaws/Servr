<Window x:Class="Servr.Presentation.View.SetDiscountDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Set Discount" Height="180" Width="220"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <StackPanel Margin="16">
        <TextBlock Text="Discount type:" Margin="0,0,0,8"/>
        <RadioButton x:Name="RadioStudent" Content="Student" GroupName="Discount" Margin="0,0,0,4"/>
        <RadioButton x:Name="RadioStaff" Content="Staff" GroupName="Discount" Margin="0,0,0,4"/>
        <RadioButton x:Name="RadioBirthday" Content="Birthday" GroupName="Discount" Margin="0,0,0,12"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="70" Click="OnCancel" Margin="0,0,8,0"/>
            <Button Content="OK" Width="70" Click="OnOk" IsDefault="True"/>
        </StackPanel>
    </StackPanel>
</Window>
