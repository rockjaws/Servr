<Window x:Class="Servr.Presentation.View.BillingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModel="clr-namespace:Servr.Presentation.ViewModel"
        xmlns:local="clr-namespace:Servr.Presentation.View"
        mc:Ignorable="d"
        Title="BillingWindow" Height="450" Width="400">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="20"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>
        </Grid.RowDefinitions>
        <DockPanel Grid.Column="1" Grid.Row="1">
            <StackPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                <Separator Margin="0,0,0,5"/>
                <TextBlock Text="{Binding Total, StringFormat='Total: {0:N2} kr.'}"
                           FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                <TextBlock Text="Signature:" Margin="0,0,0,3"/>
                <TextBox Text="{Binding Signature, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,10" Padding="4"/>
                <Button Command="{Binding PayCommand}" Content="Pay"
                        Background="LightGreen" Padding="10,5" FontSize="14"
                        HorizontalAlignment="Stretch"/>
            </StackPanel>
            <ListView ItemsSource="{Binding BillItems}">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Name}" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding Price, StringFormat='{}{0:N2} kr.'}" Margin="0,0,10,0"/>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </DockPanel>
    </Grid>
</Window>
